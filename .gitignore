name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Install GCC
        run: sudo apt-get install -y gcc
      - name: Build
        run: gcc -Wall -O2 -o scanner src/main.c src/scanner.c src/utils.c
      - name: Test
        run: ./scanner localhost 80 80
